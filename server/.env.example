# Зразок середовища. Реальний .env генерується автоматично під час першого запуску
# (bootstrap) і НЕ комітиться. У docker-compose змінні передаються середовищем.

# База даних
DATABASE_URL="postgresql://zortil:CHANGE_ME@localhost:5432/zortilwatch?schema=public"

# Секрет підпису токенів акаунта (генерується автоматично)
JWT_SECRET="CHANGE_ME"

# Спільний секрет coturn для ефемерних TURN-обліковок (генерується автоматично)
TURN_STATIC_AUTH_SECRET="CHANGE_ME"
TURN_REALM="zortilwatch.local"

# Сервер
PORT="8787"
NODE_ENV="development"
