{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ZortilWatch",
  "version": "0.0.0",
  "identifier": "com.zortilwatch.app",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "ZortilWatch",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "ZortilWatch",
    "shortDescription": "Самостійне віддалене керування робочим столом",
    "longDescription": "ZortilWatch — незалежний самостійно-хостований застосунок віддаленого доступу й керування для Windows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Ukrainian"],
        "displayLanguageSelector": true
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
